# Embedding API 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# 模型配置
# ============================================

# 模型路径（容器内路径）
MODEL_PATH=/app/models/Qwen3-VL-Embedding-2B

# 计算设备: cpu 或 cuda
DEVICE=cuda

# 嵌入向量维度
EMBEDDING_DIMENSION=2048

# ============================================
# 服务配置
# ============================================

# 服务端口
PORT=6008

# 服务监听地址
#   - 127.0.0.1: 仅本地访问（安全）
#   - 0.0.0.0:  所有网络接口（允许外部访问）
HOST=0.0.0.0

# 工作进程数（CPU 模式建议 1，GPU 模式可调整）
WORKERS=1

# ============================================
# 安全配置
# ============================================

# API 认证密钥（请修改为强密码）
API_KEY=sk-hv6xtPbK183j3RR306Fe23B6196b4d919a8e854887F6213d

# ============================================
# 性能配置
# ============================================

# OpenMP 线程数
OMP_NUM_THREADS=4

# MKL 线程数
MKL_NUM_THREADS=4

# PyTorch CUDA 内存配置
# 根据 GPU 显存调整：
#   - 8GB 显存: 512-1024
#   - 16GB 显存: 1024-2048  
#   - 24GB+ 显存: 2048-4096
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:1024

# ============================================
# 其他配置
# ============================================

# Python 输出无缓冲
PYTHONUNBUFFERED=1
