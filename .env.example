# API 访问令牌
API_KEY=your_api_key_here

# 服务器配置
PORT=6008

# 模型配置 - 支持多种嵌入模型
MODEL_PATH=./models/Qwen3-Embedding-4B                     # 默认BGE-M3模型

DEVICE=cuda  # 或 cpu
TARGET_DIM=2560  # 目标嵌入维度（BGE-M3: 1024, Qwen2: 1536, Qwen3-4B/8B: 2560，可自定义）

# 并发控制 - 优化版本，支持大规模批量处理
MAX_CONCURRENT_REQUESTS=20      # 最大并发请求数（推荐值：10-50）
MAX_BATCH_SIZE=64              # 最大批处理大小（增加以提高效率）
BATCH_TIMEOUT=0.2              # 批处理超时时间(秒)
MAX_QUEUE_SIZE=2000            # 最大队列长度（大幅增加支持更多排队）
THREAD_POOL_SIZE=8             # 线程池大小（增加处理能力）

# 错误处理和重试
MAX_RETRIES=5                  # 最大重试次数
RETRY_DELAY=0.5               # 重试延迟时间(秒)
REQUEST_TIMEOUT=300           # 请求超时时间(秒) - 增加到5分钟支持排队等待

# 低端设备（如 4 核 CPU）
#THREAD_POOL_SIZE=4

# 中端设备（如 8 核 CPU 或 基础 GPU）
THREAD_POOL_SIZE=8

# 高端 GPU 服务器
#THREAD_POOL_SIZE=32-64

# 超大规模部署（多 GPU）
#THREAD_POOL_SIZE=128-256
